def cv_show(img):
    """显示图像的辅助函数"""
    cv2.namedWindow('image', cv2.WINDOW_NORMAL)
    cv2.imshow('image', img)
    cv2.waitKey(0)
    cv2.destroyAllWindows()


class SegTransform():
    def __init__(self, path=r"D:\xm\robot\all\origin\toge", dst=r"D:\xm\robot\all\origin\enhance_seg"):
        """
        初始化分割数据集增强器
        :param path: 原始数据集路径，应包含'image'和'label'子文件夹
        :param dst: 增强后数据集保存路径
        """
        self.path = path
        self.dst = dst

        # 定义图像和标签的路径
        self.img_src = os.path.join(self.path, 'image')
        self.label_src = os.path.join(self.path, 'label')

        # 创建目标文件夹
        self.img_dst = os.path.join(self.dst, 'image')
        self.label_dst = os.path.join(self.dst, 'label')
        os.makedirs(self.img_dst, exist_ok=True)
        os.makedirs(self.label_dst, exist_ok=True)


    def random_select(self, n):
        """
        随机选择n张图像及其对应的标签进行增强
        :param n: 要增强的图像数量
        :return: 选中的图像路径列表
        """
        # 获取所有图像文件
        img_extensions = ['.bmp', '.jpg', '.jpeg', '.png']
        img_files = []

        for file in os.listdir(self.img_src):
            if any(file.lower().endswith(ext) for ext in img_extensions):
                img_path = os.path.join(self.img_src, file)
                # 检查对应的标签文件是否存在
                label_ext = '.txt'
                label_name = os.path.splitext(file)[0] + label_ext
                label_path = os.path.join(self.label_src, label_name)
                if os.path.exists(label_path):
                    img_files.append((img_path, label_path))

        if len(img_files) < n:
            print(f"警告：可用图像数量少于{n}，将使用所有{len(img_files)}张图像")
            n = len(img_files)

        # 随机选择n张图像
        random.shuffle(img_files)
        selected_pairs = img_files[:n]

        # 对选中的图像进行增强
        for i, (img_path, label_path) in enumerate(selected_pairs):
            # 读取图像（支持彩色和灰度）
            img = cv2.imread(img_path)
            if img is None:
                print(f"警告：无法读取图像 {img_path}，已跳过")
                continue

            # 读取图像尺寸
            h, w = img.shape[:2]

            # 应用增强管道
            enhanced_img, flip_types, M = self.transform_pipe(image=img, func_arg=pipe_line)

            # 保存增强后的图像
            img_ext = os.path.splitext(img_path)[1]
            img_save_path = os.path.join(self.img_dst, f"{i + 1000}{img_ext}")
            cv2.imwrite(img_save_path, enhanced_img)

            # 处理并保存增强后的标签
            label_save_path = os.path.join(self.label_dst, f"{i + 1000}.txt")
            if flip_types:
                # 转换标签坐标
                self.label_transform(img, label_path, label_save_path, flip_types, M, w, h)
            else:
                # 无需转换，直接复制
                shutil.copy(label_path, label_save_path)

            print(f"处理完成：{os.path.basename(img_save_path)}")

        return [pair[0] for pair in selected_pairs]

    def label_transform(self, image, txt_path, dst_txt_path, flip_types, M, img_w, img_h):
        """
        转换标签坐标以匹配增强后的图像
        支持任意数量的点集（不仅仅是4个点）
        """
        new_lines = []
        with open(txt_path, "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue

                data = line.strip().split()
                if len(data) < 3:  # 至少需要类别+1个点(x,y)
                    new_lines.append(line)
                    continue

                # 解析类别和点集
                class_type = data[0]
                points = list(map(float, data[1:]))  # 所有点的坐标列表 [x1,y1,x2,y2,...xn,yn]

                # 确保点的数量是偶数
                if len(points) % 2 != 0:
                    print(f"警告：标签 {txt_path} 中点的数量不正确，已跳过该行")
                    new_lines.append(line)
                    continue

                # 将点转换为元组列表 [(x1,y1), (x2,y2), ..., (xn,yn)]
                point_list = [(points[i], points[i + 1]) for i in range(0, len(points), 2)]

                # 应用所有变换
                transformed_points = point_list.copy()
                for transform_type in flip_types:
                    if transform_type == "hor":  # 水平翻转
                        transformed_points = [(1 - x, y) for (x, y) in transformed_points]
                        # 水平翻转后点的顺序需要反转以保持多边形正确
                        transformed_points = transformed_points[::-1]

                    elif transform_type == "ver":  # 垂直翻转
                        transformed_points = [(x, 1 - y) for (x, y) in transformed_points]
                        # 垂直翻转后点的顺序需要反转以保持多边形正确
                        transformed_points = transformed_points[::-1]

                    elif transform_type == "rotate":  # 旋转
                        # 将归一化坐标转换为绝对坐标
                        abs_points = np.array([[x * img_w, y * img_h] for (x, y) in transformed_points],
                                              dtype=np.float32)
                        abs_points = abs_points.reshape(-1, 1, 2)  # 调整为cv2.transform所需的格式

                        # 应用旋转变换
                        rotated_abs_points = cv2.transform(abs_points, M)
                        rotated_abs_points = rotated_abs_points.reshape(-1, 2)  # 展平

                        # 转换回归一化坐标
                        transformed_points = [(x / img_w, y / img_h) for (x, y) in rotated_abs_points]

                # 合并为新的标签行
                flattened = []
                for (x, y) in transformed_points:
                    # 确保坐标在[0, 1]范围内
                    x_clamped = max(0.0, min(1.0, round(x, 6)))
                    y_clamped = max(0.0, min(1.0, round(y, 6)))
                    flattened.extend([x_clamped, y_clamped])

                # 生成新的标注行
                new_line = f"{class_type} {' '.join(map(str, flattened))}\n"
                new_lines.append(new_line)

        # 保存转换后的标签
        with open(dst_txt_path, "w") as f:
            f.writelines(new_lines)

    def transform_pipe(self, image, func_arg):
        """增强管道，应用一系列增强操作"""
        aug_img = image.copy()
        flip_types = []
        M = None  # 用于旋转的变换矩阵

        for item in func_arg:
            func, prob = item[:2]
            args = item[2:] if len(item) > 2 else ()

            if random.random() < prob:
                result = func(aug_img, *args)
                if isinstance(result, tuple) and len(result) > 1:
                    aug_img, transform_type = result[:2]
                    if len(result) == 3:
                        M = result[2]  # 保存旋转矩阵
                    if transform_type:
                        flip_types.append(transform_type)
                else:
                    aug_img = result

        return aug_img, flip_types, M


    """光增强/衰减"""
    def light_decay_radius(self, image, strength=100, type="EN"):
        """区域光增强/衰减"""
        aug_img = image.copy()
        h, w = aug_img.shape[:2]

        # 如果是彩色图像，转换为HSV进行亮度调整（效果更好）
        is_color = len(aug_img.shape) == 3 and aug_img.shape[2] == 3
        if is_color:
            hsv = cv2.cvtColor(aug_img, cv2.COLOR_BGR2HSV)
            val_channel = hsv[:, :, 2].astype(np.float32)
        else:
            val_channel = aug_img.astype(np.float32)

        # 随机生成光斑区域
        min_radius = int(h * 0.1)
        max_radius = int(h * 0.3)
        radius = np.random.randint(min_radius, max_radius)
        pos_h = np.random.randint(radius, h - radius)
        pos_w = np.random.randint(radius, w - radius)

        # 创建网格计算距离
        y, x = np.ogrid[pos_h - radius:pos_h + radius, pos_w - radius:pos_w + radius]
        distance = np.sqrt((x - pos_w) ** 2 + (y - pos_h) ** 2)
        mask_circle = distance < radius

        # 计算光照变化强度（中心最强，向外衰减）
        light_change = (1 - distance / radius) * strength

        # 应用光照变化
        if type == "EN":  # 增强
            val_channel[y[mask_circle], x[mask_circle]] = np.clip(
                val_channel[y[mask_circle], x[mask_circle]] + light_change[mask_circle],
                0, 255
            )
        elif type == "DE":  # 衰减
            val_channel[y[mask_circle], x[mask_circle]] = np.clip(
                val_channel[y[mask_circle], x[mask_circle]] - light_change[mask_circle],
                0, 255
            )

        # 转换回原图像格式
        if is_color:
            hsv[:, :, 2] = val_channel.astype(np.uint8)
            aug_img = cv2.cvtColor(hsv, cv2.COLOR_HSV2BGR)
        else:
            aug_img = val_channel.astype(np.uint8)

        return aug_img

    """随机区域掩膜"""

    def mask_region(self, image):
        """随机遮挡部分区域"""
        aug_img = image.copy()
        h, w = aug_img.shape[:2]

        # 计算掩膜大小范围（基于图像尺寸的百分比）
        min_size = int(min(h, w) * 0.05)
        max_size = int(min(h, w) * 0.2)
        mask_size = np.random.randint(min_size, max_size)

        # 随机位置
        pos_h = np.random.randint(0, h - mask_size)
        pos_w = np.random.randint(0, w - mask_size)

        # 应用掩膜（黑色遮挡）
        aug_img[pos_h:pos_h + mask_size, pos_w:pos_w + mask_size] = 0

        return aug_img

    """图像模糊"""

    def blur(self, image, type="Gau"):
        """图像模糊处理"""
        aug_img = image.copy()
        k = random.randint(1, 5) * 2 + 1  # 确保是奇数

        if type == "Gau":
            aug_img = cv2.GaussianBlur(aug_img, (k, k), 0)
        elif type == "Med":
            aug_img = cv2.medianBlur(aug_img, k)
        elif type == "Bil":
            aug_img = cv2.bilateralFilter(aug_img, k, 75, 75)

        return aug_img

    """添加噪声"""

    def add_noise(self, image, noise_level=10):
        """为图像添加高斯噪声"""
        aug_img = image.astype(np.float32)
        noise = np.random.normal(0, noise_level, aug_img.shape).astype(np.float32)
        aug_img += noise
        np.clip(aug_img, 0, 255, out=aug_img)
        return aug_img.astype(np.uint8)

    """随机亮度和对比度调整"""

    def random_brightness_contrast(self, image, brightness_limit=0.2, contrast_limit=0.2):
        """随机调整亮度和对比度"""
        aug_img = image.copy().astype(np.float32)

        # 随机生成对比度因子和亮度偏移
        alpha = 1.0 + random.uniform(-contrast_limit, contrast_limit)
        beta = random.uniform(-brightness_limit, brightness_limit) * 255

        # 应用变换
        aug_img = np.clip(alpha * aug_img + beta, 0, 255).astype(np.uint8)

        return aug_img

    """Gamma变换"""

    def random_gamma(self, image, gamma_limit=(80, 120)):
        """随机Gamma变换"""
        aug_img = image.copy()
        gamma = random.randint(*gamma_limit) / 100.0
        inv_gamma = 1.0 / gamma

        # 创建查找表加速计算
        lookup_table = np.array([
            ((i / 255.0) ** inv_gamma) * 255
            for i in np.arange(0, 256)
        ]).astype("uint8")

        # 应用Gamma变换
        return cv2.LUT(aug_img, lookup_table)

    """水平/垂直翻转"""

    def flip(self, image, type="hor"):
        """水平或垂直翻转图像"""
        if type == "hor":
            flipped_img = cv2.flip(image, 1)  # 水平翻转
            return flipped_img, "hor"
        elif type == "ver":
            flipped_img = cv2.flip(image, 0)  # 垂直翻转
            return flipped_img, "ver"
        else:
            return image, None

    """图像旋转"""

    def rotate(self, image, angle_range=(-30, 30)):
        """随机旋转图像"""
        h, w = image.shape[:2]
        center = (w / 2, h / 2)

        # 随机生成旋转角度
        angle = random.randint(*angle_range)

        # 获取旋转矩阵
        M = cv2.getRotationMatrix2D(center, angle, 1.0)

        # 计算旋转后的图像尺寸，避免裁剪
        cos = np.abs(M[0, 0])
        sin = np.abs(M[0, 1])
        new_w = int((h * sin) + (w * cos))
        new_h = int((h * cos) + (w * sin))

        # 调整旋转矩阵以防止内容被裁剪
        M[0, 2] += (new_w / 2) - center[0]
        M[1, 2] += (new_h / 2) - center[1]

        # 应用旋转
        rotated_img = cv2.warpAffine(
            image, M, (new_w, new_h),
            borderMode=cv2.BORDER_CONSTANT,
            borderValue=(0, 0, 0) if len(image.shape) == 3 else 0
        )

        return rotated_img, "rotate", M


