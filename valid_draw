import os
import cv2
import numpy as np


def cv_show(img):
    cv2.namedWindow("img", cv2.WINDOW_NORMAL)
    cv2.imshow("img", img)
    cv2.waitKey(0)
    cv2.destroyAllWindows()


def read_txt(path):
    lines = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            lines.append(line)
    return lines


def read_img(img_path):
    gray = cv2.imread(img_path, 0)
    bgr = cv2.imread(img_path)
    return gray, bgr


def draw_rect(bgr, lines):
    h, w = 1944, 2592
    for line in lines:
        line = line.strip().split()
        points = [float(c) for c in line[1:9]]
        abs_points = np.array([
            [points[0] * w, points[1] * h],  # 第1个角点：(x1_abs, y1_abs)
            [points[2] * w, points[3] * h],  # 第2个角点：(x2_abs, y2_abs)
            [points[4] * w, points[5] * h],  # 第3个角点：(x3_abs, y3_abs)
            [points[6] * w, points[7] * h]  # 第4个角点：(x4_abs, y4_abs)
        ], dtype=np.float32)
        abs_points = abs_points.astype(np.int32)
        cv2.polylines(
            img=bgr,  # 要绘制的图像（BGR格式）
            pts=[abs_points],  # 4个角点（外层加[]，支持多组轮廓）
            isClosed=True,  # 闭合轮廓（首尾相连）
            color=(0, 0, 255),  # 线条颜色（BGR：红色）
            thickness=5  # 线条宽度
        )
        # cv2.rectangle(bgr, (x1, y1), (x2, y2), (0, 255, 0), 2)
    return bgr


if __name__ == "__main__":
    path = r"D:\all\enhance\images"
    for file in os.listdir(path):
        img_path = os.path.join(path, file)
        txt_path = img_path.replace("images", "labels").replace(".bmp", ".txt")
        gray, bgr = read_img(img_path)
        lines = read_txt(txt_path)
        print(file)
        for line in lines:
            # print(line.strip().split()[0:9])
            bgr = draw_rect(bgr, lines)
        cv_show(bgr)


