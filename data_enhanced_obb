    """光增强/衰减"""
    def Light_Decay_radius(self, image, strength=100, type="EN"):
        """
        :param image: 原图
        :param strength: 光强度
        :param type: 光增强or衰减
        :return:
        """
        aug_img = image.copy()
        if aug_img.shape == 2:
            h, w = aug_img.shape
            min_radius = int(h * 0.3) # 最小10%目标区域强光
            max_radius = int(h * 0.5)
            radius = np.random.randint(min_radius, max_radius, 1)  #
            pos_h = np.random.randint(radius, (min(h, w) - radius), 1)
            pos_w = np.random.randint(radius, 4400, 1)
            pos_h = int(pos_h[0])
            pos_w = int(pos_w[0])
            radius = int(radius[0])
            for j in range(pos_w - radius, pos_w + radius):     #列
                for i in range(pos_h - radius, pos_h + radius): #行
                    distance = np.sqrt(math.pow((pos_h - i), 2) + math.pow((pos_w - j), 2)) #欧氏距离
                    if distance < radius:
                        result = 1 - distance / radius
                        result = result * strength # 中心最强，向外衰减
                        if type == "EN":
                            aug_img[i, j] = min((aug_img[i, j] + result), 0, 255)
                            # image[i, j, 0] = min((image[i, j, 0] + result), 0, 255)
                        elif type == "DE":
                            aug_img[i, j] = min((aug_img[i, j] - result), 0, 255)
                            # image[i, j, 2] = min((image[i, j, 2] - result), 0, 255)
        aug_img = aug_img.astype(np.uint8)
        return aug_img


    """掩膜"""
    def Mask(self, image):
        aug_img = image.copy()
        h, w = 2400, 2900 # 目标主体大概位置
        min_mask, max_mask = int(h * 0.1), int(h * 0.3)
        mask_size = np.random.randint(min_mask, max_mask, 1)
        mask_coord = min(h, w) - mask_size
        pos_h = np.random.randint(mask_size, mask_coord, 1)  # 随机高取值
        pos_w = np.random.randint(1000, 4400, 1)  # 随机宽取值
        pos_h = int(pos_h[0])
        pos_w = int(pos_w[0])
        mask_size = int(mask_size[0])
        # print(min_mask, max_mask, mask_size)
        aug_img[pos_h:pos_h + mask_size, pos_w:pos_w + mask_size] = 0
        return aug_img


    """模糊"""
    def Blur(self, image, type="Gau"):
        """
        :param image: 原图
        :param blur_radius: 高斯核大小
        :return:
        """
        aug_img = image.copy()
        k = random.randint(2, 5) * 2 + 1
        if type == "Gau":
            aug_img = cv2.GaussianBlur(aug_img, (k,k), 0)
        if type == "Me":
            aug_img = cv2.GaussianBlur(aug_img, k)
        return aug_img


    """噪声"""
    def Noise(self, image, noise_level=5):
        """
        :param image: 原图
        :param noise_level: 噪声
        :return:
        """
        # 转换为float类型以避免计算溢出
        aug_img = image.astype(np.float32)
        noise = np.random.normal(0, noise_level, aug_img.shape).astype(np.float32)
        aug_img += noise
        np.clip(aug_img, 0, 255, out=aug_img)
        return aug_img.astype(np.uint8)


    """随机亮度/gamma变换"""
    def random_brightness_contrast(self, image, brightness_limit=0.1, contrast_limit=0.1):
        """
        随机调整亮度和对比度（向量化操作，速度快）
        :param image: 输入图像（cv2格式，uint8）
        :param brightness_limit: 亮度调整范围（±值，如0.2表示±20%）
        :param contrast_limit: 对比度调整范围（±值）
        :param p: 应用概率
        :return: 调整后的图像
        """
        aug_img = image.copy()
        # 随机生成对比度因子 alpha（1±contrast_limit）
        alpha = 1.0 + random.uniform(-contrast_limit, contrast_limit)
        # 随机生成亮度偏移 beta（-brightness_limit*255 ~ brightness_limit*255）
        beta = random.uniform(-brightness_limit, brightness_limit) * 255
        # 向量化操作：alpha*image + beta，避免循环
        aug_img = np.clip(alpha * aug_img + beta, 0, 255).astype(np.uint8)
        return aug_img


    """Gamma变换"""
    def random_gamma(self, image, gamma_limit=(95, 105)):
        """
        随机Gamma变换（向量化操作，速度快）
        :param image: 输入图像（cv2格式，uint8）
        :param gamma_limit: Gamma范围（整数，如(90,110)表示0.9~1.1）
        :param p: 应用概率
        :return: 变换后的图像
        """
        aug_img = image.copy()
        gamma = random.randint(*gamma_limit) / 100.0 #？？？？？
        inv_gamma = 1.0 / gamma
        lookup_table = np.array([((i / 255.0) ** inv_gamma) * 255
                                 for i in np.arange(0, 256)]).astype("uint8")
        # 应用查找表
        aug_img = cv2.LUT(aug_img, lookup_table)
        return aug_img

    "曝光-中值"
    def adjust_median(self, image):
        sub_image = image.copy()  # 复制输入图像，避免修改原图
        # 问题1修正：randint仅传2个参数，且转为标量（用.item()提取数组唯一元素）
        value = random.randint(30, 60)  # 目标亮度的中位数（50~128之间随机）

        # 计算图像中位数（仅考虑非零值更合理，避免纯黑区域干扰）
        non_zero_pixels = sub_image[sub_image > 0]  # 过滤纯黑像素（值为0）
        median_value = np.median(non_zero_pixels) if len(non_zero_pixels) > 0 else 1

        # 问题2修正：亮度调整逻辑（目标中位数 / 原始中位数 = 缩放系数alpha）
        alpha = value / median_value  # alpha：像素值的缩放比例
        # 用convertScaleAbs调整亮度（alpha=缩放系数，beta=亮度偏移量，此处无需偏移设为0）
        aug_img = cv2.convertScaleAbs(sub_image, alpha=alpha, beta=0)
        return aug_img


    '''自动曝光'''
    def adjust_mean(self, image, target_mean=100):
        value = random.randint(20, 30)
        if len(image.shape) > 2:
            gray_image = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
        else:
            gray_image = image.copy()
        current_mean = np.mean(gray_image)
        if current_mean == 0:
            return image
        exposure_ratio = target_mean / current_mean
        aug_img = np.clip(image * exposure_ratio, 0, 255).astype(np.uint8)
        return aug_img


    """水平/垂直翻转"""
    def Flip(self, image, type="hor"):
        """随机水平翻转"""
        if type=="hor":
            return cv2.flip(image, 1), type  # 1表示水平翻转
        if type=="ver":
            return cv2.flip(image, 0), type  # 0表示垂直翻转
        else:
            return image, None


    """图像旋转"""
    def Rotate(self, image, type="rotate", angle=None):
        if type=="rotate":
            h, w = image.shape[:2]
            center = (w / 2, h / 2)
            if angle is None:
                angle = random.randint(-10, 10)
                M = cv2.getRotationMatrix2D(center, angle, 1.0)
                aug_img = cv2.warpAffine(image, M, (w, h))
                # cv_show(rotated_img)
                return aug_img, type, M


