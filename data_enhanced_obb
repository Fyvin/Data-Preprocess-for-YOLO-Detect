    """对应坐标转换"""
    def Label_transform(self, image, txt_path, dst_txt_path, flip_types, M):
        h, w = 3672, 5496
        middle_h = h / 2
        middle_w = w / 2
        data_new = ""
        new_lines = []
        with (open(txt_path, "r")) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                data = line.strip().split()
                if len(data) == 9:
                    class_type = data[0]
                    points = [float(data[i]) for i in range(1, 9)]
                    p1 = (points[0], points[1])  # (x1, y1)
                    p2 = (points[2], points[3])  # (x2, y2)
                    p3 = (points[4], points[5])  # (x3, y3)
                    p4 = (points[6], points[7])  # (x4, y4)
                    for type in flip_types:
                        if type == "hor": #水平翻转
                            new_p1 = (1 - p1[0], p1[1])
                            new_p2 = (1 - p2[0], p2[1])
                            new_p3 = (1 - p3[0], p3[1])
                            new_p4 = (1 - p4[0], p4[1])
                            p1, p2, p3, p4 = new_p4, new_p3, new_p2, new_p1
                            rotated_norm_points = [p1[0], p1[1], p2[0], p2[1], p3[0], p3[1], p4[0], p4[1]]
                        # ----------------------------------------------------------
                        elif type == "ver": #垂直翻转
                            new_p1 = (p1[0], 1 - p1[1])
                            new_p2 = (p2[0], 1 - p2[1])
                            new_p3 = (p3[0], 1 - p3[1])
                            new_p4 = (p4[0], 1 - p4[1])
                            p1, p2, p3, p4 = new_p4, new_p3, new_p2, new_p1
                            rotated_norm_points = [p1[0], p1[1], p2[0], p2[1], p3[0], p3[1], p4[0], p4[1]]
                        #----------------------------------------------------------
                        elif type == "rotate": #按中心旋转
                            abs_points = np.array([
                                [p1[0] * w, p1[1] * h],
                                [p2[0] * w, p2[1] * h],
                                [p3[0] * w, p3[1] * h],
                                [p4[0] * w, p4[1] * h]
                            ], dtype=np.float32)

                            abs_points = abs_points.reshape(-1, 1, 2) # 调整输入格式：N×1×2 （-1自动计算第一个维度）
                            rotated_abs_points = cv2.transform(abs_points, M)  # 绝对值 4×1×2
                            rotated_abs_points = rotated_abs_points.reshape(-1, 2)  # 展平成 4×2
                            rotated_norm_points = []
                            for (x_abs, y_abs) in rotated_abs_points:
                                x_norm = round(x_abs / w, 6)  # 归一化x坐标
                                y_norm = round(y_abs / h, 6)  # 归一化y坐标
                                rotated_norm_points.extend([x_norm, y_norm])  # 合并为「x1,y1,...,x4,y4」

                        else:
                            new_lines.append(line)
                            continue

                        # 5. 生成新的标注行（保持原标注格式）
                    new_line = f"{class_type} {' '.join(map(str, rotated_norm_points))}\n"
                    new_lines.append(new_line)



        with open(dst_txt_path, "w") as f:
            f.writelines(new_lines)



    # 增强管道
    def transform_pipe(self, image, func_arg):
        aug_img = image.copy()
        flip_types = []
        M = ""
        for item in func_arg: # func_arg -- pipe_line
            func, prob = item[:2] # item -- (func, 0.25, "type"); func, prob-- func, 0.25
            args = item[2:] if len(item) > 2 else ()   # 函数的额外参数 # args -- "type"
            if random.random() < prob:
                result = func(aug_img, *args) # return: image, type // image, type, M
                if isinstance(result, tuple) and len(result) > 1:
                    aug_img, type = result[:2]  # image, type
                    if len(result) == 3:
                        M = result[2]
                    flip_types.append(type if type else "")  # args[0]是flip_type
                else:
                    aug_img = result
        return aug_img, flip_types, M


