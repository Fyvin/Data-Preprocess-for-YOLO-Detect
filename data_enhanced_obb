        select_shuffle_img = bmp_files[:n]                 # 选取前n张增强

        for i, bmp_path in enumerate(select_shuffle_img): # 遍历shuffle图片
            bmp = cv2.imread(bmp_path, 0)
            enhance_bmp, flip_types, M = self.transform_pipe(image=bmp, func_arg=pipe_line) # 增强图片
            s = "None" if flip_types else ""
            cv2.imwrite(f"{img_dst}/{i+3050}.bmp", enhance_bmp)

            txt_path = bmp_path.replace("image", "label").replace(".bmp", ".txt") # 单个标签路径
            dst_txt_path = f"{label_dst}/{i+3050}.txt"
            if flip_types: # 判断txt是否需要转换(含写入保存)
                self.Label_transform(bmp, txt_path, dst_txt_path, flip_types, M)
            else:
                shutil.copy(txt_path, dst_txt_path)
